# ============================================================
# AI-QAScribe Configuration
# Copy this to .env and fill in your API keys
# ============================================================

# --- Core ---
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-please

# --- Infrastructure (matches docker-compose.yml) ---
DATABASE_URL=postgresql+asyncpg://qa:qa@localhost:5432/qascribe
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=qascribe-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- AI provider keys (REQUIRED — get these from each provider) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
GOOGLE_API_KEY=AIza...

# ============================================================
#  MODELS & PRICING
#  Uncomment ONE block, comment the other.
# ============================================================

# ---- DEVELOPMENT TIER (cheap, ~$0.05/min, free Gemini tier OK) ----
GEMINI_MODEL=gemini-2.5-flash
GEMINI_INPUT_PRICE_PER_M=0.075
GEMINI_OUTPUT_PRICE_PER_M=0.30

OPENAI_STT_MODEL=whisper-1
OPENAI_STT_PRICE_PER_MINUTE=0.006

CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_INPUT_PRICE_PER_M=3.00
CLAUDE_OUTPUT_PRICE_PER_M=15.00

# ---- PRODUCTION TIER (best quality, ~$0.30/min) ----
# GEMINI_MODEL=gemini-3-pro
# GEMINI_INPUT_PRICE_PER_M=2.00
# GEMINI_OUTPUT_PRICE_PER_M=12.00
#
# OPENAI_STT_MODEL=whisper-1
# OPENAI_STT_PRICE_PER_MINUTE=0.006
#
# CLAUDE_MODEL=claude-opus-4-7
# CLAUDE_INPUT_PRICE_PER_M=5.00
# CLAUDE_OUTPUT_PRICE_PER_M=25.00

# ============================================================
#  BUDGET CONTROLS
# ============================================================
PER_JOB_MAX_USD=5.00
DEFAULT_USER_MONTHLY_BUDGET_USD=50.00
GLOBAL_DAILY_BUDGET_USD=200.00
MAX_VIDEO_DURATION_SECONDS=3600
MAX_VIDEO_FILE_SIZE_MB=500
BUDGET_SAFETY_MULTIPLIER=1.25
